# Copy to .env (never commit .env — it is in .gitignore).
# Local Homebrew PostgreSQL 18 (latest stable, verified live 2026-06-12): brew services start postgresql@18
# Then: createdb mnt_dev
#
# NOTE: sqlx 0.9 does NOT fall back to your OS username — a URL without a
# username connects as role "anonymous" and fails. Always include the user.
DATABASE_URL=postgres://YOUR_OS_USERNAME@localhost/mnt_dev

# Local/dev/e2e only: allow the OTP-logging email stub when no complete SMTP
# relay is configured. Do not set this in production; production must provide the
# full MNT_EMAIL_* SMTP group.
MNT_EMAIL_STUB_MODE=local

# Public storefront/support intake tenant. Keep KNL's seeded tenant locally unless
# the public CX tenant was re-minted via platform onboarding.
STOREFRONT_ORG_ID=00000000-0000-0000-0000-0000000000a1

# Set to true for CI where no live DB is available (uses committed .sqlx/ cache).
# SQLX_OFFLINE=true

# Regenerate the offline query cache after any schema or query change:
#   DATABASE_URL=postgres://YOUR_OS_USERNAME@localhost/mnt_dev cargo sqlx prepare --workspace -- --all-targets
# (--all-targets is REQUIRED so the cache covers #[sqlx::test] queries; CI runs clippy offline.)
# Then commit the updated .sqlx/ directory.
