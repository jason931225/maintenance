        "CARGO_PKG_VERSION_MINOR": "1",
        "CARGO_PKG_VERSION_PATCH": "0",
        "CARGO_PKG_VERSION_PRE": "",
        "SQLX_OFFLINE": "true",
        "SQLX_OFFLINE_DIR": "backend/.sqlx",
    },
    deps = [
        "//backend/crates/kernel/core:mnt-kernel-core",
        "//backend:serde",
        "//backend:serde_json",
        "//backend:sqlx",
        "//backend:thiserror",
        "//backend:time",
        "//backend:tokio",
        "//backend:uuid",
    ],
)

