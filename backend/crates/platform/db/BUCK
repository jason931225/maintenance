# Hand-maintained Buck2 Rust targets for the current backend workspace.
# Cargo.toml and Cargo.lock are dependency inputs; these checked-in labels are build authority.

load("@prelude//rust:sources.bzl", "rust_filegroup")
load("//backend/crates/platform/db:sqlx_migration_sources.bzl", "with_canonical_sqlx_migrations")

rust_library(
    name = "mnt-platform-db",
    srcs = glob(["src/**/*.rs"]),
    crate = "mnt_platform_db",
    crate_root = "src/lib.rs",
    edition = "2024",
    visibility = ["PUBLIC"],
    env = {
        "CARGO_MANIFEST_DIR": "backend/crates/platform/db",
        "CARGO_PKG_NAME": "mnt-platform-db",
        "CARGO_PKG_VERSION": "0.1.0",
