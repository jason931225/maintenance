# Rust
.tmp/
backend/target/
**/*.rs.bk

# Node
node_modules/
dist/
.cache/
.local-dev/
*.tsbuildinfo

# Python helper outputs
__pycache__/
*.py[cod]

# Swift / Gradle build outputs
**/.build/
**/.swiftpm/
**/.gradle/
**/.kotlin/
clients/kotlin/build/
clients/kotlin/**/build/

# OMC/session state — anywhere in the tree (planning artifacts in .omc/plans, .omc/specs, .omc/ultragoal ARE tracked)
**/.omc/state/
**/.omc/logs/
**/.omc/notepad.md

# OS / editor
.DS_Store
*.swp

# Env & secrets
.env
.env.*
!.env.example
**/.omc/sessions/
**/.omc/project-memory.json
.claude/worktrees/
ops/.dev-secrets/

# Linked git worktrees (77+ lane worktrees — gitlinks must never be committed)
/.worktrees/
# Local agent/session tooling (not project source)
.omc/handoffs/
.omc/*.tmp.*
.omc/.project-memory.json.tmp.*
.hermes/
.agents/
.claude/skills/
skills-lock.json

# Talos generated custody artifacts
_talos/
_talos-*/
deploy/talos/_out/
deploy/talos/**/secrets.yaml
deploy/talos/**/talosconfig
*.kubeconfig
