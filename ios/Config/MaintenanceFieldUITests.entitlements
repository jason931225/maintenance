<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Same shared keychain access group as MaintenanceFieldApp.entitlements. This
	  is what makes cross-process seeding real (not a fake): the UITests runner
	  writes the session item into THIS group, which the app target also belongs
	  to, so the app's normal restore() reads it back. Both entitlement files MUST
	  list the identical group string.
	-->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.maintenance.field.shared</string>
	</array>
</dict>
</plist>
