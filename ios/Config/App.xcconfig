// Build settings for the MaintenanceFieldApp host target (Xcode app wrapper used
// only by CI's `xcodebuild test`; the day-to-day build is `swift build`).
//
// The hermetic Simulator gate uses the repository defaults below and does not
// require an Apple identity secret. Signed device/distribution builds may
// override `MNT_IOS_BUNDLE_ID` and `MNT_IOS_TEAM_ID` with their registered App
// ID and Team ID. See ios/Config/README.md for the separate release boundary.
//
// Local fallbacks below let `xcodebuild` resolve the project when a developer
// opens it without the CI variables. They are repo defaults for the CI/test
// wrapper only; signed/distributable builds still must prove the registered App
// ID, capabilities, and provisioning profile match before release.

// --- Identity ---
// Bundle id is com.maintenance.field (matches the Android applicationId + the
// keychain-access-group baked into the entitlements: <prefix>com.maintenance.field.shared).
// This is the App ID to register under Team 98Q89GFZWP in the Apple Developer
// portal WITH the Associated Domains capability enabled (or let Xcode automatic
// signing create it on first build). Overridable via the MNT_IOS_BUNDLE_ID /
// MNT_IOS_TEAM_ID build settings if a different identity is ever needed.
MNT_IOS_BUNDLE_ID = $(MNT_IOS_BUNDLE_ID:default=com.maintenance.field)
MNT_IOS_TEAM_ID = $(MNT_IOS_TEAM_ID:default=98Q89GFZWP)

PRODUCT_BUNDLE_IDENTIFIER = $(MNT_IOS_BUNDLE_ID)
DEVELOPMENT_TEAM = $(MNT_IOS_TEAM_ID)

// --- Shared Keychain access group ---
// The no-fakes session seeding writes the real session token pair into the
// Keychain from the UITests process; the app reads it back through its NORMAL
// launch path (KeychainSessionTokenStore.init / restore()). For one process to
// read another's Keychain item both must share this access group.
//
// IMPORTANT: this literal is only a CI override hint. On a properly-signed
// device build "$(AppIdentifierPrefix)" is the Team ID, but on the ad-hoc-signed
// Simulator build it is a placeholder, so both the app
// (KeychainAccessGroup.resolveShared) and the test seeder
// (RealSessionSeed.resolvedAccessGroup) resolve the ACTUAL granted group at
// runtime by probing the Keychain — they never rely on this exact string
// matching. The override below is used only if a probe write to it succeeds.
MNT_IOS_KEYCHAIN_GROUP = $(MNT_IOS_TEAM_ID).com.maintenance.field.shared

// --- Simulator test build: ad-hoc sign so entitlements actually embed ---
// The shared keychain-access-group seeding requires the keychain-access-groups
// entitlement to be PRESENT in the built binary; an entirely unsigned build
// (CODE_SIGNING_ALLOWED=NO) embeds no entitlements and SecItem returns
// errSecMissingEntitlement (-34018). The iOS Simulator honors ad-hoc signing
// ("-") with entitlements, which is enough for cross-process keychain sharing
// there — no real provisioning profile or registered bundle id needed. The
// RealSessionSeed fails the suite if the shared group is absent or cannot be
// read back, so an entitlement/signing regression cannot produce a false green.
CODE_SIGN_STYLE = Manual
CODE_SIGNING_REQUIRED = YES
CODE_SIGNING_ALLOWED = YES
CODE_SIGN_IDENTITY = -

INFOPLIST_KEY_NSCameraUsageDescription = 작업 증빙 사진을 촬영하기 위해 카메라 접근 권한이 필요합니다.

SWIFT_VERSION = 6.1
IPHONEOS_DEPLOYMENT_TARGET = 17.0
