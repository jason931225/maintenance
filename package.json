{
  "name": "maintenance-api-clients",
  "private": true,
  "type": "module",
  "workspaces": [
    "clients/ts",
    "web",
    "coss-rn"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "gen:api:ts": "openapi-typescript backend/openapi/openapi.yaml -o clients/ts/src/schema.d.ts",
    "gen:api:kotlin": "node scripts/generate-kotlin-client.mjs",
    "gen:api:swift": "node scripts/generate-swift-client.mjs",
    "gen:api:portable": "npm run gen:api:ts && npm run gen:api:kotlin",
    "gen:api": "npm run gen:api:portable && npm run gen:api:swift",
    "check:ts": "tsc -p tsconfig.json",
    "check:kotlin": "node scripts/run-kotlin-build.mjs",
    "check:swift": "swift build --package-path clients/swift",
    "check:openapi-app": "node scripts/check-openapi-app.mjs",
    "check:dispatch-map": "node scripts/check-dispatch-map.mjs",
    "check:foundation-gates": "node scripts/check-foundation-gates.mjs",
    "check:api-drift:portable": "npm run gen:api:portable && git diff --exit-code -- clients/ts clients/kotlin",
    "check:api-drift:swift": "npm run gen:api:swift && git diff --exit-code -- clients/swift",
    "test:contract": "tsx scripts/contract-roundtrip.ts",
    "web:dev": "npm --workspace web run dev",
    "web:build": "npm --workspace web run build",
    "web:lint": "npm --workspace web run lint",
    "web:test": "npm --workspace web run test",
    "check:payroll": "node scripts/check-payroll-domain.mjs",
    "check:erp": "node scripts/check-erp-domain.mjs",
    "check:comms-webmail": "node scripts/check-comms-webmail.mjs",
    "check:registry-equipment-rest": "node scripts/check-registry-equipment-rest.mjs",
    "check:collaboration-app": "node scripts/check-collaboration-app.mjs",
    "check:production-hardening": "node scripts/check-production-hardening.mjs",
    "check:enterprise-ux-parity": "node scripts/check-enterprise-ux-parity.mjs",
    "check:people-hr-maturity": "node scripts/check-people-hr-maturity.mjs",
    "check:payroll-release-gate": "node scripts/check-payroll-release-gate.mjs",
    "check:financial-maturity": "node scripts/check-financial-maturity.mjs",
    "check:cx-reporting-maturity": "node scripts/check-cx-reporting-maturity.mjs",
    "check:operations-intelligence-maturity": "node scripts/check-operations-intelligence-maturity.mjs",
    "check:browser-persona-matrix": "node scripts/check-browser-persona-matrix.mjs",
    "check:g004-identity-foundation": "node scripts/check-g004-identity-foundation.mjs",
    "check:g005-workflow-lifecycle": "node scripts/check-g005-workflow-lifecycle.mjs",
    "check:g006-asset-dispatch-lifecycle": "node scripts/check-g006-asset-dispatch-lifecycle.mjs",
    "check:g007-collaboration-mobile-lifecycle": "node scripts/check-g007-collaboration-mobile-lifecycle.mjs",
    "check:g008-payroll-readiness": "node scripts/check-g008-payroll-readiness.mjs"
  },
  "dependencies": {
    "openapi-fetch": "0.17.0",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "2.38.0",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "openapi-typescript": "7.13.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
