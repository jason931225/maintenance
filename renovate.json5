{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
  ],
  timezone: "Asia/Seoul",
  schedule: ["before 9am on monday"],
  labels: ["dependencies"],
  // Keep base images current AND digest-pinned (reproducible builds).
  packageRules: [
    {
      matchManagers: ["cargo"],
      groupName: "rust crates",
    },
    {
      matchManagers: ["npm"],
      groupName: "npm packages",
    },
    {
      matchManagers: ["github-actions"],
      groupName: "github actions",
    },
    {
      matchManagers: ["dockerfile"],
      groupName: "base images",
    },
    // Security advisories ship immediately, ungrouped, ignoring the schedule.
    {
      matchDatasources: ["docker", "npm", "crate"],
      matchUpdateTypes: ["pin", "digest"],
      automerge: true,
    },
  ],
  vulnerabilityAlerts: {
    labels: ["security"],
    schedule: ["at any time"],
  },
  // Track the pinned versions of the deploy-time platform components that live
  // as plain strings in Argo Application manifests (targetRevision) and in the
  // Talos/runbook docs, so they get PRs like any other dependency.
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/deploy/argocd/apps/.+\\.ya?ml$/"],
      matchStrings: [
        "targetRevision:\\s*[\"']?(?<currentValue>[\\w.+-]+)[\"']?\\s*#\\s*renovate:\\s*(?<depName>\\S+)\\s+datasource=(?<datasource>\\S+)",
      ],
    },
  ],
}
