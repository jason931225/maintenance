+    /// Direct dev-dependency packages of workspace members. These are the only
+    /// dev roots that may be emitted when workspace dev dependencies are enabled.
+    pub fn workspace_dev_dependency_roots(&self) -> BTreeSet<&'meta Manifest> {
+        if !self.config.include_workspace_dev_dependencies {
+            return BTreeSet::new();
+        }
+
+        self.workspace_members
+            .iter()
+            .flat_map(|member| &self.pkgid_to_node[&member.id].deps)
+            .filter(|node_dep| {
+                node_dep
+                    .dep_kinds
+                    .iter()
+                    .any(|kind| kind.kind == DepKind::Dev)
+            })
+            .map(|node_dep| self.pkgid_to_pkg[&node_dep.pkg])
+            .collect()
+    }
