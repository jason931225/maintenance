{
  "schema_version": 2,
  "faces": [
    {
      "id": "first-party-buck",
      "source_roots": ["backend/app", "backend/crates", "backend/ci", "tools/buck/gen_first_party.py"],
      "output_patterns": ["backend/app/**/BUCK", "backend/crates/**/BUCK", "backend/ci/**/BUCK"],
      "writer": {"kind": "repo-exec", "executable": "tools/buck/generated-face-first-party.sh", "target": "//tools/buck:generated-face-first-party"},
      "drift_gate": {"tier": "cheap", "kind": "writer-snapshot"}
    },
    {
      "id": "reindeer-third-party-rust",
      "source_roots": ["backend/Cargo.toml", "backend/Cargo.lock", "third-party/rust/reindeer.toml", "third-party/rust/reindeer"],
      "output_patterns": ["third-party/rust/BUCK"],
      "writer": {"kind": "repo-exec", "executable": "tools/buck/generated-face-reindeer.sh", "target": "//tools/buck:generated-face-reindeer"},
      "drift_gate": {"tier": "expensive", "kind": "writer-snapshot"}
    },
    {
      "id": "openapi-typescript",
      "source_roots": ["backend/openapi", "scripts/generate-ts-client.mjs"],
      "output_patterns": ["clients/ts/src/schema.d.ts"],
      "writer": {"kind": "repo-exec", "executable": "tools/buck/generated-face-openapi-ts.sh", "target": "//tools/buck:generated-face-openapi-ts"},
      "drift_gate": {"tier": "cheap", "kind": "writer-snapshot"}
    },
    {
      "id": "openapi-kotlin",
      "source_roots": ["backend/openapi", "clients/kotlin-generator-config.yaml", "clients/kotlin-generator-templates", "scripts/generate-kotlin-client.mjs", "scripts/lib/kotlin-discriminator-unions.mjs"],
      "output_patterns": ["clients/kotlin/.openapi-generator/**", "clients/kotlin/gradle/**", "clients/kotlin/src/main/**", "clients/kotlin/build.gradle", "clients/kotlin/gradle.properties", "clients/kotlin/gradlew", "clients/kotlin/gradlew.bat", "clients/kotlin/settings.gradle"],
      "writer": {"kind": "repo-exec", "executable": "tools/buck/generated-face-openapi-kotlin.sh", "target": "//tools/buck:generated-face-openapi-kotlin"},
      "drift_gate": {"tier": "expensive", "kind": "writer-snapshot"}
    },
    {
      "id": "openapi-swift",
      "source_roots": ["backend/openapi", "clients/swift/openapi-generator-config.yaml", "scripts/generate-swift-client.mjs"],
      "output_patterns": ["clients/swift/Sources/MaintenanceAPIClient/Generated/**"],
      "writer": {"kind": "repo-exec", "executable": "tools/buck/generated-face-openapi-swift.sh", "target": "//tools/buck:generated-face-openapi-swift"},
      "drift_gate": {"tier": "expensive", "kind": "writer-snapshot"}
    }
  ]
}
