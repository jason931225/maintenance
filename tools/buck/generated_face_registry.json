{
  "schema_version": 1,
  "faces": [
    {
      "id": "first-party-buck",
      "source_roots": ["backend/app", "backend/crates", "backend/ci"],
      "output_roots": ["backend/app", "backend/crates", "backend/ci"],
      "writer": {
        "command": "python3 tools/buck/gen_first_party.py",
        "target": "//tools/buck:gen-first-party"
      },
      "drift_gate": "tools/buck/preflight.sh"
    },
    {
      "id": "reindeer-third-party-rust",
      "source_roots": ["backend/Cargo.toml", "backend/Cargo.lock", "third-party/rust/reindeer.toml", "third-party/rust/reindeer"],
      "output_roots": ["third-party/rust"],
      "writer": {
        "command": "third-party/rust/buckify.sh",
        "target": "//third-party/rust:buckify"
      },
      "drift_gate": "third-party/rust/buckify.sh --check"
    },
    {
      "id": "openapi-typescript",
      "source_roots": ["backend/openapi", "scripts/generate-ts-client.mjs"],
      "output_roots": ["clients/ts/src"],
      "writer": {
        "command": "npm run gen:api:ts",
        "target": "//clients/ts:generate"
      },
      "drift_gate": "npm run check:api-drift:portable"
    },
    {
      "id": "openapi-kotlin",
      "source_roots": ["backend/openapi", "clients/kotlin-generator-config.yaml", "clients/kotlin-generator-templates", "scripts/generate-kotlin-client.mjs", "scripts/lib/kotlin-discriminator-unions.mjs"],
      "output_roots": ["clients/kotlin"],
      "writer": {
        "command": "npm run gen:api:kotlin",
        "target": "//clients/kotlin:generate"
      },
      "drift_gate": "npm run check:api-drift:portable"
    },
    {
      "id": "openapi-swift",
      "source_roots": ["backend/openapi", "clients/swift/openapi-generator-config.yaml", "scripts/generate-swift-client.mjs"],
      "output_roots": ["clients/swift/Sources/MaintenanceAPIClient/Generated"],
      "writer": {
        "command": "npm run gen:api:swift",
        "target": "//clients/swift:generate"
      },
      "drift_gate": "npm run check:api-drift:swift"
    }
  ]
}
