{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "types": ["node"]
  },
  "include": [
    "clients/ts/src/**/*.ts",
    "clients/ts/src/**/*.d.ts",
    "clients/ts/test/**/*.ts",
    "scripts/**/*.ts"
  ]
}
